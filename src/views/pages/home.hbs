
<script>
function waitForGoogleMaps(cb) {
  const i = setInterval(() => {
    if (window.google && window.google.maps) {
      clearInterval(i);
      cb();
    }
  }, 50);
}

waitForGoogleMaps(initHomeMap);
</script>

