# =============================================================================
# Buff-Bugger environment variables
# =============================================================================
#
# Copy this file to `.env` and fill in the values.
#
#   cp .env.example .env
#
# The `.env` file is gitignored. NEVER commit real secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL — database credentials
# -----------------------------------------------------------------------------
# These are read by both the Postgres container and the Express app.
# The database is initialized from src/init_data/create.sql and insert.sql
# on first run.

POSTGRES_USER=buffbugger
POSTGRES_PASSWORD=change_me_before_running
POSTGRES_DB=buffbugger_dev


# -----------------------------------------------------------------------------
# Database host
# -----------------------------------------------------------------------------
# Use `db` when running via docker-compose (matches the service name).
# Use `localhost` if you're running Postgres standalone on your host machine.

HOST=db


# -----------------------------------------------------------------------------
# Session management
# -----------------------------------------------------------------------------
# Used by express-session to sign cookies. Must be a long random string.
# Generate one with:
#
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

SESSION_SECRET=replace_with_a_long_random_string


# -----------------------------------------------------------------------------
# Google Maps JavaScript API
# -----------------------------------------------------------------------------
# Required for rendering the map on the home page and for displaying
# bug markers. Get a key from:
#
#   https://console.cloud.google.com/google/maps-apis/
#
# Restrict the key to your local and deployed origins before going live.

GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here


# -----------------------------------------------------------------------------
# Anthropic Claude API
# -----------------------------------------------------------------------------
# Required for the Bug-i-dex chatbot feature. Get a key from:
#
#   https://console.anthropic.com/
#
# The chat feature will be disabled gracefully if this is missing, but the
# rest of the app will continue to work.

ANTHROPIC_API_KEY=your_anthropic_api_key_here


# -----------------------------------------------------------------------------
# Node environment (optional)
# -----------------------------------------------------------------------------
# Set to `production` when deployed. Leave as `development` locally.

NODE_ENV=development
